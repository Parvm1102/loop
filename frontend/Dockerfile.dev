# Hot-reload dev image for the Orbit frontend.
# Runs the Vite dev server (HMR) instead of the nginx production build.
FROM node:22-slim
WORKDIR /app

# Install deps first for better layer caching. The source is bind-mounted at
# runtime (see docker-compose.dev.yml), so we only need package manifests here.
COPY package.json ./
RUN npm install

EXPOSE 5173
# Polling makes file-watching reliable across Docker bind mounts (esp. Windows).
ENV CHOKIDAR_USEPOLLING=true
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
